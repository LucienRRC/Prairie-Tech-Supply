<section class="page-hero">
  <div class="container">
    <p class="eyebrow">PRAIRIE TECH INVENTORY</p>
    <h1>Products</h1>
    <p>Electronics selected for work, study, gaming, and connected homes.</p>
  </div>
</section>

<section class="container section">
  <form action="<%= products_path %>" method="get" class="product-search" role="search">
    <div class="search-field search-keyword">
      <%= label_tag :keyword, "Search products" %>
      <%= text_field_tag :keyword, @keyword,
        placeholder: "Search product names and descriptions",
        autocomplete: "off" %>
    </div>

    <div class="search-field search-category">
      <%= label_tag :category_id, "Category" %>
      <%= select_tag :category_id,
        options_from_collection_for_select(@categories, :id, :name, @selected_category_id),
        include_blank: "All categories" %>
    </div>

    <div class="search-field search-filter">
      <%= label_tag :filter, "Product filter" %>
      <%= select_tag :filter,
        options_for_select(@filter_options, @selected_filter) %>
    </div>

    <div class="search-actions">
      <%= submit_tag "Apply", name: nil, class: "search-button" %>
      <% if @keyword.present? || @selected_category_id.present? || @selected_filter.present? %>
        <%= link_to "Clear filters", products_path, class: "clear-search" %>
      <% end %>
    </div>
  </form>

  <% if @keyword.present? || @selected_category_id.present? || @selected_filter.present? %>
    <p class="search-summary" role="status">
      <strong><%= pluralize(@products.total_count, "product") %></strong> found
      <% if @keyword.present? %>for &ldquo;<%= @keyword %>&rdquo;<% end %>
      <% if @selected_category_id.present? %>
        in <%= @categories.find { |category| category.id.to_s == @selected_category_id.to_s }&.name || "the selected category" %>
      <% end %>
      <% if @selected_filter == "on_sale" %>
        &middot; currently on sale
      <% elsif @selected_filter == "new" %>
        &middot; added within the past 3 days
      <% elsif @selected_filter == "recently_updated" %>
        &middot; updated within the past 3 days
      <% end %>
    </p>
  <% end %>

  <div class="product-grid">
    <%= render partial: "product_card", collection: @products, as: :product %>
  </div>

  <% if @products.empty? %>
    <div class="empty-products">
      <h2>No products found</h2>
      <p>Try another keyword, category, or product filter.</p>
      <%= link_to "View all products", products_path, class: "text-link" %>
    </div>
  <% elsif @products.total_pages > 1 %>
    <div class="pagination-wrap">
      <%= paginate @products %>
    </div>
  <% end %>
</section>
